def parse_fasta(fasta_string):
    sequences = []
    for line in fasta_string.strip().splitlines(): #strip() removes whitespace from the edges of the string, splitlines() splits the strings into lines (iterable)
        if not line.startswith(">"): 
            sequences.append(line.strip()) #works because my FASTA files has onlu single-line sequences
    return sequences

#rule  gluing together pairs of reads that overlap by more than half their length.
#we can expect sequences to look like ['ATTAGACCTG', 'CCTGCCGGAA', 'AGACCTGCCG', 'GCCGGAATAC']


sequences = parse_fasta(fasta_string)   

def find_superstring(sequences):
    seqs = sequences.copy()
    n = len(sequences[0])
    half = n//2 + 1

    while len(seqs) > 1:
        encontrou_merge = False  # Para saber se encontrou algo nesta iteração
        
        for i in range(len(seqs)):
            for j in range(len(seqs)):
                #fazer o overlap
                if i==j:
                    continue
                
                for overlap in range(n, half - 1, -1):
                    if seqs[i].startswith(seqs[j][-overlap:]):
                        merged=seqs[j]+seqs[i][overlap:]
                        idx1, idx2 = sorted([i, j], reverse=True)
                        seqs.pop(idx1)
                        seqs.pop(idx2)

                        seqs.append(merged)
                        encontrou_merge = True
                        break

                    if seqs[i].endswith(seqs[j][:overlap]):
                        merged = seqs[i]+seqs[j][overlap:]
                        idx1, idx2 = sorted([i, j], reverse=True)
                        seqs.pop(idx1)
                        seqs.pop(idx2)
                        
                        seqs.append(merged)
                        encontrou_merge = True
                        break
                if encontrou_merge:
                    break
            if encontrou_merge:
                break    
    return seqs[0]

#works for small sequences, but takes a reeeeally long time checking for each possible overlap
